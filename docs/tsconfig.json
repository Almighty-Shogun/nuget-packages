{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": [
            "esnext",
            "dom"
        ],

        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "allowSyntheticDefaultImports": true,

        "paths": {
            "@almighty-shogun/prototype-extensions": [
                "../packages/prototype-extensions/src/index.ts"
            ],
            "@almighty-shogun/utils": [
                "../packages/utils/src/index.ts"
            ],
            "@almighty-shogun/vue-utils": [
                "../packages/vue-utils/src/index.ts"
            ],
            "@almighty-shogun/webkit-native-bridge": [
                "../packages/webkit-native-bridge/src/index.ts"
            ]
        }
    },
    "include": [
        "./vite-env.d.ts",
        "./.vitepress/**/*.ts",
        "./.vitepress/**/*.vue",
    ],
    "exclude": [
        "node_modules",
        ".vitepress/dist",
        ".vitepress/cache"
    ],
    "vueCompilerOptions": {
        "target": 3.5,
        "strictTemplates": false
    }
}
