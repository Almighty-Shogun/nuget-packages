<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <TargetFramework>net10.0</TargetFramework>

        <Authors>Almighty-Shogun</Authors>
        <PackageId>AlmightyShogun.RemoteCommands</PackageId>

        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Description>A simple C# implementation for remote commands using attributes.</Description>

        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/Almighty-Shogun/NuGetPackages/packages/AlmightyShogun.RemoteCommands</RepositoryUrl>
        <PackageProjectUrl>https://github.com/Almighty-Shogun/NuGetPackages/packages/AlmightyShogun.RemoteCommands</PackageProjectUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="README.md">
            <Pack>true</Pack>
            <PackagePath>\</PackagePath>
        </None>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AlmightyShogun.Logging\AlmightyShogun.Logging.csproj"/>
        <ProjectReference Include="..\AlmightyShogun.Utils\AlmightyShogun.Utils.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="10.0.1"/>
    </ItemGroup>

</Project>
