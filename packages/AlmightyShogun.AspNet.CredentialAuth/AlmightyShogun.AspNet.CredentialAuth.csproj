<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <TargetFramework>net10.0</TargetFramework>

        <Authors>Almighty-Shogun</Authors>
        <PackageId>AlmightyShogun.AspNet.CredentialAuth</PackageId>
        <RootNamespace>AlmightyShogun.AspNet.CredentialAuth</RootNamespace>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>

        <PackageIcon>icon.png</PackageIcon>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Description>A C# library that adds username or email password authentication, refresh sessions, and password reset helpers to ASP.NET Core APIs.</Description>

        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/Almighty-Shogun/nuget-packages/packages/AlmightyShogun.AspNet.CredentialAuth</RepositoryUrl>
        <PackageProjectUrl>https://github.com/Almighty-Shogun/nuget-packages/packages/AlmightyShogun.AspNet.CredentialAuth</PackageProjectUrl>
    </PropertyGroup>

    <ItemGroup>
        <None Include="icon.png" Pack="true" PackagePath=""/>
        <None Update="README.md" Pack="true" PackagePath=""/>
    </ItemGroup>

    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App"/>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.10"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\AlmightyShogun.AspNet.JwtAuth\AlmightyShogun.AspNet.JwtAuth.csproj"/>
        <ProjectReference Include="..\AlmightyShogun.AspNet.Utils\AlmightyShogun.AspNet.Utils.csproj"/>
        <ProjectReference Include="..\AlmightyShogun.AspNet.Validation\AlmightyShogun.AspNet.Validation.csproj"/>
    </ItemGroup>

</Project>
